@model LoginViewModel

@{
    ViewData["Title"] = "Đăng Nhập";
}

<div class="register-container">
    <div class="razor-card auth-card">
        <h2 class="neon-text text-center mb-4">Đăng Nhập</h2>
        <div class="auth-container">
        <form asp-action="Login" asp-controller="Account" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <input asp-for="UserName" class="form-control neon-input" placeholder="Tên đăng nhập" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <input asp-for="Password" class="form-control neon-input" type="password" placeholder="Mật khẩu" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn-auth">Đăng Nhập</button>
        </form>
        </div>
    </div>
</div>

<script src="https://js.hcaptcha.com/1/api.js" async defer></script>