<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hưng - Razer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page-wrapper">
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3">
                <div class="container">
                    <a class="navbar-brand neon-text" asp-area="" asp-controller="Home" asp-action="Home">Hưng - Razer</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Chuyển đổi điều hướng">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex">
                        <!-- Danh sách các liên kết chính -->
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Home">Trang Chủ</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Sản Phẩm</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Category" asp-action="Index">Danh Mục</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Chính Sách Bảo Mật</a>
                            </li>
                        </ul>
                        <!-- Thanh tìm kiếm -->
                        <form class="search-form mx-3" asp-controller="Home" asp-action="Search" method="get">
                            <input type="search" name="query" placeholder="Tìm kiếm..." aria-label="Search" />
                            <button type="submit">Tìm</button>
                        </form>
                        <!-- Nhóm các nút Đăng nhập/Đăng ký và Giỏ hàng -->
                        <ul class="navbar-nav ms-auto">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item d-flex align-items-center">
                                    <span class="nav-link neon-text me-2">Xin chào, @User.Identity.Name!</span>
                                    <a class="nav-link btn btn-razer" asp-area="" asp-controller="Account" asp-action="Logout">Đăng Xuất</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link btn btn-razer me-2" asp-area="" asp-controller="Account" asp-action="Login">Đăng Nhập</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link btn btn-razer" asp-area="" asp-controller="Account" asp-action="Register">Đăng Ký</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link cart-link" asp-controller="Home" asp-action="Cart">
                                    Giỏ Hàng (@(ViewBag.CartCount ?? 0))
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        @if (ViewContext?.RouteData?.Values["Action"]?.ToString() == "Home" && ViewContext?.RouteData?.Values["Controller"]?.ToString() == "Home")
        {
            @RenderBody()
        }
        else
        {
            <div class="container">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
        }

        <footer class="footer">
            <div class="container">
                <div class="footer-content">
                    <div class="footer-item">
                        <h3>Về Chúng Tôi</h3>
                        <p>Hưng - Razer - Cửa hàng công nghệ phong cách.</p>
                    </div>
                    <div class="footer-item">
                        <h3>Hỗ Trợ</h3>
                        <p>Liên hệ qua email: hung.support@razermyweb.com</p>
                    </div>
                    <div class="footer-item">
                        <h3>Theo Dõi</h3>
                        <div class="social-icons">
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-twitter"></i></a>
                            <a href="#"><i class="fab fa-instagram"></i></a>
                            <a href="#"><i class="fab fa-linkedin-in"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>