@model _1298_DUYHUNG.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Thanh Toán";
}

<section class="py-2">
    <div class="container px-4 px-lg-5 mt-5">
        <h2 class="neon-text">Thanh Toán</h2>
        <div class="row">
            <!-- Form nhập thông tin giao hàng -->
            <div class="col-md-6">
                <div class="auth-card">
                    <h3 class="neon-text mb-4">Thông Tin Giao Hàng</h3>
                    <form asp-action="ConfirmCheckout" method="post">
                        <div class="mb-3">
                            <label asp-for="FullName" class="neon-label">Họ Tên</label>
                            <input asp-for="FullName" class="form-control neon-input" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="neon-label">Số Điện Thoại</label>
                            <input asp-for="PhoneNumber" class="form-control neon-input" required pattern="[0-9]{10}" title="Số điện thoại phải có 10 chữ số" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Address" class="neon-label">Địa Chỉ</label>
                            <textarea asp-for="Address" class="form-control neon-input" rows="3" required></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                        <!-- Truyền danh sách sản phẩm đã chọn -->
                        @for (int i = 0; i < Model.SelectedItems.Count; i++)
                        {
                            <input type="hidden" name="SelectedItems[@i].ProductId" value="@Model.SelectedItems[i].ProductId" />
                            <input type="hidden" name="SelectedItems[@i].ProductName" value="@Model.SelectedItems[i].ProductName" />
                            <input type="hidden" name="SelectedItems[@i].Price" value="@Model.SelectedItems[i].Price" />
                            <input type="hidden" name="SelectedItems[@i].Quantity" value="@Model.SelectedItems[i].Quantity" />
                            <input type="hidden" name="SelectedItems[@i].ImageUrl" value="@Model.SelectedItems[i].ImageUrl" />
                        }
                        <div class="text-center">
                            <button type="submit" class="btn btn-neon">Xác Nhận Đơn Hàng</button>
                        </div>
                    </form>
                </div>
            </div>
            <!-- Danh sách sản phẩm đã chọn -->
            <div class="col-md-6">
                <div class="auth-card">
                    <h3 class="neon-text mb-4">Sản Phẩm Đã Chọn</h3>
                    @if (Model.SelectedItems.Any())
                    {
                        <table class="table table-dark table-striped">
                            <thead>
                                <tr>
                                    <th>Sản Phẩm</th>
                                    <th>Giá</th>
                                    <th>Số Lượng</th>
                                    <th>Tổng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.SelectedItems)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 50px; height: 50px; object-fit: cover; margin-right: 10px;" />
                                                <span>@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td>@item.Price.ToString("#,##0") USD</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.Total.ToString("#,##0") USD</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Tổng Cộng:</strong></td>
                                    <td><strong>@Model.TotalAmount.ToString("#,##0") USD</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <p class="text-center" style="color: #cccccc;">Không có sản phẩm nào được chọn.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}