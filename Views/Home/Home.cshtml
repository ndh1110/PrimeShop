@{
    ViewData["Title"] = "Trang Chủ";
}
<section class="py-2">
    <div class="container px-4 px-lg-5 mt-5">
        <div class="main-content">
            <h2 class="neon-text">Chào mừng đến với Hưng - Razer!</h2>
            <p>Khám phá các sản phẩm công nghệ cao cấp từ Razer với thiết kế hiện đại và hiệu năng vượt trội. Hãy bắt đầu hành trình của bạn ngay hôm nay!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-neon">Xem Sản Phẩm</a>
        </div>
    </div>
</section>

<style>
    .main-content {
        padding: 40px;
        text-align: center;
    }

    .main-content h2 {
        font-size: 2.5em;
        margin-bottom: 20px;
    }

    .main-content p {
        font-size: 1.2em;
        margin-bottom: 30px;
    }
</style>