@model IEnumerable<_1298_DUYHUNG.Models.Product>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<_1298_DUYHUNG.Models.User> SignInManager
@inject UserManager<_1298_DUYHUNG.Models.User> UserManager

@{
    ViewData["Title"] = "Sản Phẩm";
    bool isAdmin = User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin");
}

<section class="py-2">
    <div class="container px-4 px-lg-5 mt-5">
        <h2 class="neon-text">Danh Sách Sản Phẩm</h2>

        <!-- Thanh tìm kiếm -->
        <form class="search-form mb-3" asp-controller="Home" asp-action="Search" method="get">
            <input type="search" name="query" placeholder="Tìm kiếm..." aria-label="Search" />
            <button type="submit" class="btn btn-razer">Tìm</button>
        </form>

        @if (isAdmin)
        {
            <div class="mb-3">
                <a asp-action="Create" class="btn btn-neon">Thêm Sản Phẩm Mới</a>
            </div>
        }
        <div class="product-grid" id="product-list">
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="product-card">
                        <img src="@item.ImageUrl" class="product-image" alt="@item.Name">
                        <div class="product-info">
                            <div class="product-details">
                                <h5>@Html.DisplayFor(modelItem => item.Name)</h5>
                                <p class="description">@item.Description</p>
                                <p class="price">@item.Price.ToString("#,##0") USD</p>
                            </div>
                            <div class="button-group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">Xem</a>
                                <a asp-controller="Home" asp-action="AddToCart" asp-route-id="@item.Id" asp-route-quantity="1" class="btn btn-success">Thêm vào giỏ</a>
                                @if (isAdmin)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success">Sửa</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?');">
                                        <button type="submit" class="btn btn-danger">Xóa</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-center" style="color: #cccccc;">Không có sản phẩm nào.</p>
            }
        </div>

        <!-- Phân trang -->
        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link neon-page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">Trước</a>
                        </li>
                    }
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link neon-page-link" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }
                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link neon-page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">Sau</a>
                        </li>
                    }
                </ul>
            </nav>
        }

        <!-- Nút "Sản phẩm miễn phí" ở góc phải màn hình (chỉ hiển thị cho tài khoản thường) -->
        @if (!isAdmin)
        {
            <button id="free-product-button" class="btn btn-success free-button" onmouseover="moveButton(this)">Sản phẩm miễn phí</button>
        }
    </div>
</section>

@section Scripts {
    <script>
        let isAdmin = @(isAdmin ? "true" : "false");

        // Hàm di chuyển nút "Sản phẩm miễn phí" khi rê chuột vào
        function moveButton(button) {
            // Lấy kích thước của cửa sổ trình duyệt
            const maxX = window.innerWidth - button.offsetWidth - 20; // Trừ đi chiều rộng của nút và padding
            const maxY = window.innerHeight - button.offsetHeight - 20; // Trừ đi chiều cao của nút và padding

            // Tính toán vị trí ngẫu nhiên mới trên toàn màn hình
            const newX = Math.random() * maxX;
            const newY = Math.random() * maxY;

            // Đặt vị trí mới cho nút
            button.style.position = 'fixed';
            button.style.left = newX + 'px';
            button.style.top = newY + 'px';
        }
    </script>
}