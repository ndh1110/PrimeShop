@model List<(User User, string Role)>
@using _1298_DUYHUNG.Models

@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Sử dụng layout chung
}

<section class="py-5">
    <div class="container px-4 px-lg-5 mt-5">
        <h2 class="neon-text">Quản lý tài khoản</h2>

        <!-- Thông báo -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success neon-alert">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger neon-alert">@TempData["Error"]</div>
        }

        <!-- Thanh tìm kiếm -->
        <div class="d-flex justify-content-center mb-4">
            <form class="search-form" asp-action="AccountManagement" asp-area="Admin" method="get">
                <input type="text" name="query" value="@ViewBag.Query" placeholder="Tìm kiếm tài khoản..." aria-label="Search" />
                <button type="submit" class="btn btn-razer">Tìm</button>
            </form>
        </div>

        <!-- Bảng danh sách tài khoản -->
        <div class="table-responsive">
            <table class="table table-dark table-bordered neon-table">
                <thead>
                    <tr>
                        <th class="neon-label">Tên</th>
                        <th class="neon-label">Email</th>
                        <th class="neon-label">SĐT</th>
                        <th class="neon-label">Role</th>
                        <th class="neon-label">Ngày tạo</th>
                        <th class="neon-label">Lần đăng nhập cuối</th>
                        <th class="neon-label">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.User.UserName</td>
                                <td>@item.User.Email</td>
                                <td>@item.User.PhoneNumber</td>
                                <td>@item.Role</td>
                                <td>@item.User.DateCreated.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(item.User.LastLogin?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa đăng nhập")</td>
                                <td>
                                    <a asp-action="Edit" asp-area="Admin" asp-route-id="@item.User.Id" class="btn btn-success neon-btn">Sửa</a>
                                    <form asp-action="Delete" asp-area="Admin" asp-route-id="@item.User.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tài khoản này?');" style="display:inline;">
                                        <button type="submit" class="btn btn-danger neon-btn">Xóa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">Không có tài khoản nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Phân trang -->
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link neon-page-link" asp-action="AccountManagement" asp-area="Admin" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-query="@ViewBag.Query">Trước</a>
                    </li>
                }
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link neon-page-link" asp-action="AccountManagement" asp-area="Admin" asp-route-page="@i" asp-route-query="@ViewBag.Query">@i</a>
                    </li>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link neon-page-link" asp-action="AccountManagement" asp-area="Admin" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-query="@ViewBag.Query">Sau</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</section>